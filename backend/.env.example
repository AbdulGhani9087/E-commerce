# Backend Environment Variables
# Copy this file to .env and fill in the values

# MongoDB connection string (from MongoDB Atlas)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ecommerce

# Port for the server (Render sets this automatically)
PORT=4000

# JWT Secret - use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_here

# Your Render backend URL (set this after deploying to Render)
BACKEND_URL=https://your-backend-name.onrender.com

# Comma-separated list of allowed frontend origins (your Vercel URLs)
ALLOWED_ORIGINS=https://your-admin.vercel.app,https://your-frontend.vercel.app
